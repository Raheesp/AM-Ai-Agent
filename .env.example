# Sara AI Agent — Environment Configuration
# Copy this to .env and fill in your values

# ── Telegram ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=

# ── WhatsApp (Meta Cloud API) ─────────────────────────────────────────────────
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=sara_verify_123

# ── Exotel (Voice Calls) ──────────────────────────────────────────────────────
EXOTEL_SID=
EXOTEL_TOKEN=
EXOTEL_FROM_NUMBER=

# ── Ollama (Local LLM) ────────────────────────────────────────────────────────
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:latest

# ── File Paths ────────────────────────────────────────────────────────────────
DB_PATH=sara.db
AGENT_CONFIG=agent_config.json
INCENTIVE_EXCEL=Sales_Managers_Take_Home_Analysis__Same_month_MF___MSIL_Scheme_.xlsx
RESOURCES_DIR=resources
